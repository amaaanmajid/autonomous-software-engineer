# ── LLM ──────────────────────────────────────────────────────────────────────
# Get a free Gemini API key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Ollama fallback (optional — run: ollama pull codellama:7b)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=codellama:7b

# ── GitHub ────────────────────────────────────────────────────────────────────
# Create a PAT at https://github.com/settings/tokens (needs repo + pull_request scopes)
GITHUB_TOKEN=your_github_pat_here
GITHUB_REPO_OWNER=your_github_username
GITHUB_REPO_NAME=autonomous-software-engineer

# ── Paths ─────────────────────────────────────────────────────────────────────
WORKSPACE_DIR=/tmp/ase_workspace
FAISS_INDEX_PATH=./data/faiss_index
SYMBOL_INDEX_PATH=./data/symbol_index.json

# ── Docker ────────────────────────────────────────────────────────────────────
DOCKER_IMAGE_NAME=ase-test-runner
DOCKER_TIMEOUT=120

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000
